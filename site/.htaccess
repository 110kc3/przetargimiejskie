# Apache config for przetargimiejskie.pl on OVH shared hosting.
#
# The site is fully static (HTML + JSON in /data + extension.zip). This file is
# copied into the deploy by build-site.sh and uploaded by the OVH workflow.
# Everything is wrapped in <IfModule> so that, if a module isn't loaded, Apache
# ignores the block instead of returning 500 for the whole site.

# Serve index.html for directory requests (/archiwum/, /privacy/, /).
DirectoryIndex index.html

# Treat text responses as UTF-8 (Polish diacritics in the HTML and JSON).
AddDefaultCharset utf-8
<IfModule mod_mime.c>
  AddType application/json .json
  AddCharset utf-8 .json .html .css .js .svg
</IfModule>

# Force HTTPS. OVH terminates TLS at its load balancer and forwards the original
# scheme in X-Forwarded-Proto, so we test THAT (not %{HTTPS}, which can read
# "off" even on an HTTPS hit behind the LB and cause a redirect loop). Only
# redirects when the forwarded scheme is not https — loop-safe.
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Redirect ONLY when the forwarded scheme is explicitly "http". If the header
  # is ever absent, we do nothing (site stays reachable) rather than risk a loop.
  RewriteCond %{HTTP:X-Forwarded-Proto} =http
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Caching: the /data JSON changes whenever the pipeline refreshes, and the HTML
# is small — keep both revalidating so visitors never see stale auctions. The
# downloadable extension archive can cache for a day.
<IfModule mod_headers.c>
  <FilesMatch "\.(json|html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.zip$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

# Compress text responses (HTML/JSON/CSS/JS/SVG) — big win for the data files.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# Don't expose directory listings if an index is ever missing.
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>
