{
  "manifest_version": 3,
  "name": "Przetargi miejskie",
  "short_name": "Przetargi miejskie",
  "version": "1.28.0",
  "description": "Przetargi miejskie na Śląsku: Gliwice, Katowice, Bytom, Zabrze, Sosnowiec, Rybnik i inne. Historia cen, zł/m²..",
  "author": "110kc3",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://zgm-gliwice.pl/*",
    "https://bip.katowice.eu/*",
    "https://i-biip.um.bytom.pl/*",
    "https://www.bytom.pl/*",
    "https://raw.githubusercontent.com/110kc3/przetargimiejskie/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Przetargi miejskie",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://zgm-gliwice.pl/*",
        "https://bip.katowice.eu/*",
        "https://katowice.eu/*",
        "https://i-biip.um.bytom.pl/*",
        "https://www.bytom.pl/*",
        "https://bytom.pl/*",
        "https://bip.zgm.rybnik.pl/*",
        "https://bip.myslowice.pl/*",
        "https://www.bip.swietochlowice.pl/*",
        "https://bip.swietochlowice.pl/*",
        "https://bielsko-biala.pl/*",
        "https://www.bielsko-biala.pl/*"
      ],
      "js": [
        "i18n.js",
        "normalize.js",
        "watchlist.js",
        "settings.js",
        "dealscore.js",
        "sites/registry.js",
        "sites/finn-common.js",
        "sites/gliwice.js",
        "sites/katowice.js",
        "sites/bytom.js",
        "sites/rybnik.js",
        "sites/myslowice.js",
        "sites/swietochlowice.js",
        "sites/bielsko.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": []
}
