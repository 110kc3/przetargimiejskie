{
  "manifest_version": 3,
  "name": "przetargimiejskie - śląsk",
  "short_name": "przetargimiejskie",
  "version": "1.10.0",
  "description": "Historia miejskich przetargów na nieruchomości (Gliwice, Katowice, Bytom, Zabrze, Sosnowiec): dawne ceny, zł/m², terminy wadium i oględzin, powiadomienia o aukcjach.",
  "author": "110kc3",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://zgm-gliwice.pl/*",
    "https://bip.katowice.eu/*",
    "https://i-biip.um.bytom.pl/*",
    "https://www.bytom.pl/*",
    "https://raw.githubusercontent.com/110kc3/przetargimiejskie/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "przetargimiejskie - śląsk",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://zgm-gliwice.pl/*",
        "https://bip.katowice.eu/*",
        "https://i-biip.um.bytom.pl/*",
        "https://www.bytom.pl/*"
      ],
      "js": [
        "i18n.js",
        "normalize.js",
        "watchlist.js",
        "settings.js",
        "sites/registry.js",
        "sites/gliwice.js",
        "sites/katowice.js",
        "sites/bytom.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": []
}
