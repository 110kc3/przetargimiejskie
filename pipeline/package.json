{
  "name": "przetargimiejskie-pipeline",
  "version": "0.1.0",
  "description": "Scrapes municipal property auction results and builds data/<city>/*.json for the Chrome extension",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "refresh": "node src/refresh.js",
    "crawl:results": "node src/cities/gliwice/crawl-results.js",
    "crawl:active": "node src/cities/gliwice/crawl-active.js",
    "test": "node --test --test-reporter=dot tests/parse-result.test.js"
  }
}
